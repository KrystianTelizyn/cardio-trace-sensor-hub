# Used by docker-compose.dev.yml (sensor-hub, backend-api, simulation) and local `make dev`.
# Copy to `.env` and align with cardio-trace-backend-api expectations (Django `DB_*`, secrets, etc.).

DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=cardio_trace
DB_HOST=localhost
DB_PORT=5432

REDIS_URL=redis://localhost:6379/0
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_SUBSCRIBE_PATTERN=example/#

# URL of backend API (HTTP client integration is not wired yet in the hub).
BACKEND_API_BASE_URL=http://localhost:8000

# Host port mappings (compose only)
BACKEND_API_HOST_PORT=8000
IOT_SIM_HOST_PORT=8001
SENSOR_HUB_HOST_PORT=8002
REDIS_HOST_PORT=6379
MQTT_HOST_PORT=1883
